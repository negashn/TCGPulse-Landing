<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TCGPulse — Real-Time TCG Market Intelligence</title>
  <style>
    /* ── Reset & Root ──────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --void:      #04020c;
      --deep:      #07041a;
      --card:      #0c0920;
      --panel:     #110e26;
      --gold:      #d97706;
      --gold-lt:   #f59e0b;
      --gold-br:   #fbbf24;
      --purple:    #7c3aed;
      --purple-lt: #a855f7;
      --purple-dim:#2d1f5e;
      --cyan:      #00e5ff;
      --slate:     #94a3b8;
      --white:     #f1f5f9;
      --border:    #1e1640;
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--void);
      color: var(--white);
      font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
      overflow-x: hidden;
      min-height: 100vh;
    }
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--purple-dim); border-radius: 4px; }

    /* ── Animations ────────────────────────────────────────────────────── */
    @keyframes fadeUp   { from { opacity:0; transform:translateY(32px); } to { opacity:1; transform:translateY(0); } }
    @keyframes shimmer  { 0%{background-position:-600px 0} 100%{background-position:600px 0} }
    @keyframes pulse    { 0%,100%{opacity:1} 50%{opacity:.4} }
    @keyframes spin     { to { transform: rotate(360deg); } }
    @keyframes floatUp  { 0%{transform:translateY(0) scale(1);opacity:.7} 100%{transform:translateY(-100vh) scale(.3);opacity:0} }
    @keyframes glow     { 0%,100%{box-shadow:0 0 20px #7c3aed44,0 0 60px #7c3aed22} 50%{box-shadow:0 0 40px #7c3aed88,0 0 120px #7c3aed44} }
    @keyframes borderPulse { 0%,100%{border-color:#2d1f5e} 50%{border-color:#7c3aed} }
    @keyframes countDown { from{opacity:0;transform:scale(.85)} to{opacity:1;transform:scale(1)} }
    @keyframes lineGrow  { from{width:0} to{width:100%} }
    @keyframes hueShift  { 0%{filter:hue-rotate(0deg)} 100%{filter:hue-rotate(360deg)} }

    .fade-up  { animation: fadeUp .7s cubic-bezier(.22,1,.36,1) both; }
    .fade-up-2{ animation: fadeUp .7s .15s cubic-bezier(.22,1,.36,1) both; }
    .fade-up-3{ animation: fadeUp .7s .30s cubic-bezier(.22,1,.36,1) both; }
    .fade-up-4{ animation: fadeUp .7s .45s cubic-bezier(.22,1,.36,1) both; }
    .fade-up-5{ animation: fadeUp .7s .60s cubic-bezier(.22,1,.36,1) both; }
    .pulse    { animation: pulse 2s ease-in-out infinite; }

    /* ── Particle Canvas ───────────────────────────────────────────────── */
    #stars {
      position: fixed; inset: 0; pointer-events: none; z-index: 0;
    }

    /* ── Global layout ─────────────────────────────────────────────────── */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

    /* ── NAV ───────────────────────────────────────────────────────────── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 16px 24px;
      display: flex; align-items: center; justify-content: space-between;
      background: linear-gradient(180deg, rgba(4,2,12,.95) 0%, transparent 100%);
      backdrop-filter: blur(8px);
    }
    .nav-logo {
      display: flex; align-items: center; gap: 10px;
      font-size: 20px; font-weight: 900; letter-spacing: -.5px;
    }
    .nav-logo-icon {
      width: 32px; height: 32px; border-radius: 8px;
      background: linear-gradient(135deg, var(--purple), var(--gold));
      display: flex; align-items: center; justify-content: center;
      font-size: 16px;
    }
    .nav-logo span.pulse-word { color: var(--gold-br); }
    .nav-logo span.tcg-word   { color: var(--white); }
    .nav-badge {
      font-size: 10px; font-weight: 700; color: var(--gold-br);
      background: #1c0e0288; border: 1px solid #d9770644;
      border-radius: 4px; padding: 3px 8px; letter-spacing: .08em;
    }

    /* ── HERO ──────────────────────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      text-align: center;
      padding: 120px 24px 80px;
      position: relative;
    }
    /* Radial glow behind hero */
    .hero::before {
      content: '';
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -55%);
      width: 800px; height: 600px;
      background: radial-gradient(ellipse, #7c3aed18 0%, #d9770608 40%, transparent 70%);
      pointer-events: none; z-index: 0;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase;
      color: var(--gold-lt); background: #1c0e0255;
      border: 1px solid #d9770644; border-radius: 999px;
      padding: 6px 16px; margin-bottom: 28px;
    }
    .hero-eyebrow .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold-lt); animation: pulse 1.5s ease-in-out infinite; }
    .hero-title {
      font-size: clamp(42px, 8vw, 88px);
      font-weight: 900; line-height: 1.0; letter-spacing: -2px;
      margin-bottom: 12px;
    }
    .hero-title .line1 { display: block; color: var(--white); }
    .hero-title .line2 {
      display: block;
      background: linear-gradient(90deg, var(--gold) 0%, var(--gold-br) 50%, var(--purple-lt) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: clamp(15px, 2.5vw, 20px);
      color: var(--slate); max-width: 580px; line-height: 1.65;
      margin: 20px auto 48px;
    }
    .hero-sub strong { color: var(--white); font-weight: 600; }

    /* Countdown */
    .countdown-wrap {
      display: flex; gap: 12px; justify-content: center;
      margin-bottom: 52px; flex-wrap: wrap;
    }
    .countdown-unit {
      display: flex; flex-direction: column; align-items: center;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 14px; padding: 16px 20px; min-width: 80px;
      animation: glow 3s ease-in-out infinite;
    }
    .countdown-unit:nth-child(2) { animation-delay: .75s; }
    .countdown-unit:nth-child(3) { animation-delay: 1.5s; }
    .countdown-unit:nth-child(4) { animation-delay: 2.25s; }
    .countdown-num {
      font-size: 36px; font-weight: 900; color: var(--white);
      font-variant-numeric: tabular-nums; line-height: 1;
      animation: countDown .3s ease both;
    }
    .countdown-lbl {
      font-size: 9px; font-weight: 700; letter-spacing: .1em;
      text-transform: uppercase; color: var(--slate); margin-top: 6px;
    }
    .countdown-sep {
      font-size: 28px; font-weight: 900; color: var(--purple-dim);
      align-self: center; padding-bottom: 8px;
    }

    /* Email form */
    .signup-form {
      display: flex; gap: 0; max-width: 480px; width: 100%;
      margin: 0 auto; position: relative;
    }
    .signup-input {
      flex: 1; padding: 16px 20px; font-size: 15px;
      background: var(--card); color: var(--white);
      border: 1px solid var(--border); border-right: none;
      border-radius: 12px 0 0 12px; outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    .signup-input::placeholder { color: #475569; }
    .signup-input:focus {
      border-color: var(--purple);
      box-shadow: 0 0 0 3px #7c3aed22;
    }
    .signup-btn {
      padding: 16px 28px; font-size: 14px; font-weight: 800;
      letter-spacing: .04em; cursor: pointer; border: none;
      border-radius: 0 12px 12px 0;
      background: linear-gradient(135deg, var(--gold) 0%, var(--purple) 100%);
      color: #fff; transition: opacity .2s, transform .1s;
      white-space: nowrap;
    }
    .signup-btn:hover  { opacity: .9; }
    .signup-btn:active { transform: scale(.98); }
    .signup-note {
      font-size: 11px; color: #475569; margin-top: 12px; text-align: center;
    }
    /* Success state */
    .signup-success {
      display: none; align-items: center; justify-content: center; gap: 8px;
      padding: 14px 24px; border-radius: 12px;
      background: #14532d33; border: 1px solid #16a34a66;
      color: #22c55e; font-weight: 700; font-size: 14px;
      max-width: 480px; width: 100%; margin: 0 auto;
    }

    /* Scroll indicator */
    .scroll-hint {
      position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center; gap: 6px;
      opacity: .5;
    }
    .scroll-hint span { font-size: 10px; letter-spacing: .1em; color: var(--slate); }
    .scroll-arrow {
      width: 20px; height: 20px; border-right: 2px solid var(--slate);
      border-bottom: 2px solid var(--slate);
      transform: rotate(45deg);
      animation: pulse 1.5s ease-in-out infinite;
    }

    /* ── SECTION SHARED ────────────────────────────────────────────────── */
    section { padding: 80px 0; position: relative; z-index: 1; }
    .section-eyebrow {
      font-size: 11px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase;
      color: var(--gold-lt); margin-bottom: 12px; display: block;
    }
    .section-title {
      font-size: clamp(28px, 5vw, 48px);
      font-weight: 900; letter-spacing: -1px; margin-bottom: 16px;
    }
    .section-sub {
      font-size: 16px; color: var(--slate); line-height: 1.7; max-width: 560px;
    }
    .divider {
      height: 1px; background: linear-gradient(90deg, transparent, var(--border), transparent);
      margin: 0 auto;
    }

    /* ── FEATURES STRIP ────────────────────────────────────────────────── */
    .features-strip {
      background: var(--deep);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .features-strip .container {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
    }
    .feature-item {
      padding: 32px 28px; display: flex; flex-direction: column; gap: 8px;
      border-right: 1px solid var(--border);
    }
    .feature-item:last-child { border-right: none; }
    .feature-icon {
      font-size: 26px; margin-bottom: 4px;
    }
    .feature-title { font-size: 15px; font-weight: 800; color: var(--white); }
    .feature-desc  { font-size: 13px; color: var(--slate); line-height: 1.6; }

    /* ── GAMES SECTION ─────────────────────────────────────────────────── */
    .games-section { padding: 96px 0; }
    .games-header { text-align: center; margin-bottom: 60px; }
    .games-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .game-card {
      position: relative; overflow: hidden;
      background: var(--card); border: 1px solid var(--border);
      border-radius: 20px; padding: 36px 28px;
      transition: transform .25s, border-color .25s, box-shadow .25s;
      cursor: default;
    }
    .game-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 24px 60px rgba(0,0,0,.6);
    }
    .game-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    }
    .game-card.op::before    { background: linear-gradient(90deg, #ef4444, #f97316); }
    .game-card.db::before    { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
    .game-card.ua::before    { background: linear-gradient(90deg, #3b82f6, #a855f7); }
    .game-card:hover.op      { border-color: #ef444455; box-shadow: 0 24px 60px #ef444422; }
    .game-card:hover.db      { border-color: #f59e0b55; box-shadow: 0 24px 60px #f59e0b22; }
    .game-card:hover.ua      { border-color: #3b82f655; box-shadow: 0 24px 60px #3b82f622; }
    /* Glow orb */
    .game-card .orb {
      position: absolute; top: -40px; right: -40px;
      width: 160px; height: 160px; border-radius: 50%;
      opacity: .07; pointer-events: none;
    }
    .game-card.op .orb { background: radial-gradient(circle, #ef4444, transparent); }
    .game-card.db .orb { background: radial-gradient(circle, #f59e0b, transparent); }
    .game-card.ua .orb { background: radial-gradient(circle, #3b82f6, transparent); }

    .game-logo-wrap {
      width: 60px; height: 60px; border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; margin-bottom: 20px;
    }
    .game-card.op .game-logo-wrap { background: #ef444418; border: 1px solid #ef444433; }
    .game-card.db .game-logo-wrap { background: #f59e0b18; border: 1px solid #f59e0b33; }
    .game-card.ua .game-logo-wrap { background: #3b82f618; border: 1px solid #3b82f633; }

    .game-name {
      font-size: 20px; font-weight: 900; margin-bottom: 6px;
    }
    .game-card.op .game-name { color: #f97316; }
    .game-card.db .game-name { color: #fbbf24; }
    .game-card.ua .game-name { color: #60a5fa; }

    .game-sub  { font-size: 12px; color: var(--slate); margin-bottom: 20px; font-weight: 600; letter-spacing: .04em; }
    .game-desc { font-size: 14px; color: #64748b; line-height: 1.7; margin-bottom: 24px; }
    .game-features { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .game-features li {
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; color: var(--slate);
    }
    .game-features li::before {
      content: ''; flex-shrink: 0;
      width: 6px; height: 6px; border-radius: 50%;
    }
    .game-card.op .game-features li::before { background: #ef4444; }
    .game-card.db .game-features li::before { background: #f59e0b; }
    .game-card.ua .game-features li::before { background: #3b82f6; }

    .game-status {
      display: inline-flex; align-items: center; gap: 6px;
      margin-top: 24px; font-size: 11px; font-weight: 700; letter-spacing: .06em;
      padding: 5px 12px; border-radius: 999px;
    }
    .game-card.op .game-status { color: #f97316; background: #f9731618; border: 1px solid #f9731633; }
    .game-card.db .game-status { color: #fbbf24; background: #fbbf2418; border: 1px solid #fbbf2433; }
    .game-card.ua .game-status { color: #60a5fa; background: #60a5fa18; border: 1px solid #60a5fa33; }
    .game-status .dot-sm { width: 5px; height: 5px; border-radius: 50%; background: currentColor; animation: pulse 1.5s ease-in-out infinite; }

    /* ── HOW IT WORKS ──────────────────────────────────────────────────── */
    .how-section {
      padding: 96px 0;
      background: linear-gradient(180deg, transparent 0%, var(--deep) 30%, var(--deep) 70%, transparent 100%);
    }
    .how-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px;
      margin-top: 56px; position: relative;
    }
    /* Connecting line */
    .how-grid::before {
      content: ''; position: absolute;
      top: 48px; left: calc(12.5% + 28px); right: calc(12.5% + 28px);
      height: 1px; background: linear-gradient(90deg, transparent, var(--purple-dim), var(--purple-dim), var(--purple-dim), transparent);
      z-index: 0;
    }
    .how-step {
      display: flex; flex-direction: column; align-items: center;
      text-align: center; padding: 0 20px; position: relative; z-index: 1;
    }
    .how-step-num {
      width: 56px; height: 56px; border-radius: 50%;
      background: var(--card); border: 1px solid var(--purple-dim);
      display: flex; align-items: center; justify-content: center;
      font-size: 20px; font-weight: 900; color: var(--purple-lt);
      margin-bottom: 20px; position: relative;
    }
    .how-step-num::after {
      content: ''; position: absolute; inset: -4px;
      border-radius: 50%; border: 1px solid var(--purple);
      opacity: 0; transition: opacity .3s;
    }
    .how-step:hover .how-step-num::after { opacity: 1; }
    .how-step-title { font-size: 15px; font-weight: 800; color: var(--white); margin-bottom: 8px; }
    .how-step-desc  { font-size: 13px; color: var(--slate); line-height: 1.6; }

    /* ── STATS BAND ────────────────────────────────────────────────────── */
    .stats-band {
      padding: 56px 0;
      background: var(--card);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .stats-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 0;
    }
    .stat-item {
      text-align: center; padding: 0 24px;
      border-right: 1px solid var(--border);
    }
    .stat-item:last-child { border-right: none; }
    .stat-num {
      font-size: clamp(28px, 4vw, 44px); font-weight: 900;
      background: linear-gradient(135deg, var(--gold-br), var(--purple-lt));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; line-height: 1.1; margin-bottom: 6px;
    }
    .stat-label { font-size: 12px; color: var(--slate); font-weight: 600; letter-spacing: .04em; }

    /* ── BOTTOM CTA ────────────────────────────────────────────────────── */
    .cta-section {
      padding: 120px 0;
      text-align: center;
      position: relative; overflow: hidden;
    }
    .cta-section::before {
      content: ''; position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 700px; height: 500px;
      background: radial-gradient(ellipse, #7c3aed12 0%, transparent 65%);
      pointer-events: none;
    }
    .cta-section .section-title { margin-bottom: 20px; }
    .cta-section .section-sub   { margin: 0 auto 48px; }
    .cta-cards {
      display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
      margin-bottom: 48px;
    }
    .cta-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 12px; padding: 12px 20px;
      display: flex; align-items: center; gap: 10px;
      font-size: 13px; font-weight: 600; color: var(--slate);
    }
    .cta-card .chip {
      font-size: 10px; font-weight: 800; letter-spacing: .06em;
      padding: 2px 7px; border-radius: 4px;
    }
    .cta-card.free  .chip { color: #22c55e; background: #14532d33; border: 1px solid #16a34a55; }
    .cta-card.early .chip { color: var(--gold-br); background: #1c0e0233; border: 1px solid #d9770655; }
    .cta-card.api   .chip { color: var(--purple-lt); background: #1a0a3a33; border: 1px solid #7c3aed55; }

    /* ── FOOTER ────────────────────────────────────────────────────────── */
    footer {
      padding: 32px 24px;
      border-top: 1px solid var(--border);
      background: var(--deep);
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 16px;
    }
    .footer-logo { font-size: 16px; font-weight: 900; }
    .footer-logo .pulse-word { color: var(--gold-br); }
    .footer-links {
      display: flex; gap: 24px;
    }
    .footer-links a {
      font-size: 12px; color: #475569; text-decoration: none;
      transition: color .2s;
    }
    .footer-links a:hover { color: var(--slate); }
    .footer-copy { font-size: 11px; color: #334155; width: 100%; text-align: center; }

    /* ── FLOATING PARTICLES ────────────────────────────────────────────── */
    .particles { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
    .particle {
      position: absolute; border-radius: 50%;
      animation: floatUp linear infinite;
    }

    /* ── RESPONSIVE ────────────────────────────────────────────────────── */
    @media (max-width: 900px) {
      .games-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
      .how-grid   { grid-template-columns: repeat(2, 1fr); gap: 40px; }
      .how-grid::before { display: none; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .stat-item  { padding: 24px; border-right: none; border-bottom: 1px solid var(--border); }
      .stat-item:nth-child(2n) { border-right: none; }
      .features-strip .container { grid-template-columns: 1fr; }
      .feature-item { border-right: none; border-bottom: 1px solid var(--border); }
      .feature-item:last-child { border-bottom: none; }
    }
    @media (max-width: 600px) {
      .hero-title { letter-spacing: -1px; }
      .countdown-unit { min-width: 64px; padding: 12px 14px; }
      .countdown-num { font-size: 28px; }
      .signup-form { flex-direction: column; }
      .signup-input  { border-right: 1px solid var(--border); border-radius: 12px; }
      .signup-btn    { border-radius: 12px; }
      .how-grid   { grid-template-columns: 1fr; }
      .stats-grid { grid-template-columns: 1fr 1fr; }
      .cta-cards  { flex-direction: column; align-items: center; }
      nav         { padding: 14px 16px; }
      .nav-badge  { display: none; }
      footer      { flex-direction: column; align-items: center; text-align: center; }
      .footer-links { justify-content: center; }
    }
  </style>
</head>
<body>

<!-- ── Floating particles ──────────────────────────────────────────────── -->
<div class="particles" id="particles"></div>

<!-- ── Canvas stars ───────────────────────────────────────────────────── -->
<canvas id="stars"></canvas>

<!-- ══════════════════════════════════════════════════════════════════════
     NAV
══════════════════════════════════════════════════════════════════════ -->
<nav>
  <div class="nav-logo">
    <div class="nav-logo-icon">⚡</div>
    <div>
      <span class="tcg-word">TCG</span><span class="pulse-word">Pulse</span>
    </div>
  </div>
  <div class="nav-badge">COMING SOON</div>
</nav>

<!-- ══════════════════════════════════════════════════════════════════════
     HERO
══════════════════════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="container" style="position:relative;z-index:1;">

    <div class="hero-eyebrow fade-up">
      <span class="dot"></span>
      Early Access Opening Soon
    </div>

    <h1 class="hero-title">
      <span class="line1 fade-up-2">Real-Time TCG</span>
